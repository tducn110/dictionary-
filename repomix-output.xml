            letterSpacing: '0.35em',
            color: '#2C2824',
          }}
        >
          font of intent
        </p>
      </header>

      {/* Hero — everything shares the left edge, entrance animation */}
      <main
        className="relative z-10 flex-1 flex flex-col justify-center"
