          animation: 'foiEntrance 800ms cubic-bezier(0.25, 0.1, 0.25, 1) both',
        }}
      >
        {/* Headline — THE moment */}
        <h1
          className="text-[#2C2824]"
          style={{
            fontFamily: "'Playfair Display', serif",
            fontStyle: 'italic',
